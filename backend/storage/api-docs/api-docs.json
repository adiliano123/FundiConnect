{
    "openapi": "3.0.0",
    "info": {
        "title": "FundiConnect API",
        "description": "REST API for FundiConnect — a platform connecting customers with verified skilled technicians in Tanzania.",
        "contact": {
            "email": "support@fundiconnect.co.tz"
        },
        "license": {
            "name": "MIT"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "API Base URL"
        }
    ],
    "paths": {
        "/auth/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Register a new user",
                "operationId": "c47a1b563e5e8bc3c7b962f893981e84",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Jane Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "jane@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "secret123"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "example": "secret123"
                                    },
                                    "role": {
                                        "type": "string",
                                        "enum": [
                                            "customer",
                                            "technician"
                                        ],
                                        "example": "customer"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "255712345678"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Registration successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "token": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "$ref": "#/components/schemas/User"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login and get access token",
                "operationId": "1ff9c65c5cd1a8e0786e318eed856972",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "jane@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "secret123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "token": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "$ref": "#/components/schemas/User"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials"
                    },
                    "403": {
                        "description": "Account suspended"
                    }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout (revoke current token)",
                "operationId": "eae6a8251a6469bbabe454860f64cf37",
                "responses": {
                    "200": {
                        "description": "Logged out",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/auth/me": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Get currently authenticated user",
                "operationId": "257a57ee6760f86fb4b11ff94dba1f38",
                "responses": {
                    "200": {
                        "description": "Authenticated user",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "user": {
                                            "$ref": "#/components/schemas/User"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "User": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "example": "john@example.com"
                    },
                    "role": {
                        "type": "string",
                        "enum": [
                            "customer",
                            "technician",
                            "admin"
                        ]
                    },
                    "phone": {
                        "type": "string",
                        "example": "255712345678"
                    },
                    "avatar_url": {
                        "type": "string",
                        "example": "https://..."
                    },
                    "city": {
                        "type": "string",
                        "example": "Dar es Salaam"
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    },
                    "is_verified": {
                        "type": "boolean",
                        "example": false
                    }
                },
                "type": "object"
            },
            "Category": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Electrical"
                    },
                    "slug": {
                        "type": "string",
                        "example": "electrical"
                    },
                    "description": {
                        "type": "string"
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    },
                    "technicians_count": {
                        "type": "integer",
                        "example": 12
                    }
                },
                "type": "object"
            },
            "Technician": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 3
                    },
                    "bio": {
                        "type": "string"
                    },
                    "experience_years": {
                        "type": "integer",
                        "example": 5
                    },
                    "hourly_rate": {
                        "type": "number",
                        "example": 15000
                    },
                    "rating": {
                        "type": "number",
                        "example": 4.8
                    },
                    "total_reviews": {
                        "type": "integer",
                        "example": 32
                    },
                    "is_available": {
                        "type": "boolean",
                        "example": true
                    },
                    "verification_status": {
                        "type": "string",
                        "enum": [
                            "pending",
                            "verified",
                            "rejected"
                        ]
                    },
                    "user": {
                        "$ref": "#/components/schemas/User"
                    },
                    "category": {
                        "$ref": "#/components/schemas/Category"
                    }
                },
                "type": "object"
            },
            "Booking": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 21
                    },
                    "booking_number": {
                        "type": "string",
                        "example": "BK-20240001"
                    },
                    "description": {
                        "type": "string",
                        "example": "Fix kitchen light"
                    },
                    "address": {
                        "type": "string",
                        "example": "123 Msimbazi St"
                    },
                    "city": {
                        "type": "string",
                        "example": "Dar es Salaam"
                    },
                    "scheduled_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "pending",
                            "accepted",
                            "awaiting_payment",
                            "paid",
                            "rejected",
                            "in_progress",
                            "completed",
                            "cancelled"
                        ]
                    },
                    "estimated_cost": {
                        "type": "number",
                        "example": 25000
                    },
                    "final_cost": {
                        "type": "number",
                        "example": 22000
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "customer": {
                        "$ref": "#/components/schemas/User"
                    },
                    "technician": {
                        "$ref": "#/components/schemas/Technician"
                    },
                    "category": {
                        "$ref": "#/components/schemas/Category"
                    }
                },
                "type": "object"
            },
            "Payment": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 10
                    },
                    "reference": {
                        "type": "string",
                        "example": "FC-PAY-XXXXXXXX"
                    },
                    "amount": {
                        "type": "number",
                        "example": 25000
                    },
                    "platform_fee": {
                        "type": "number",
                        "example": 2500
                    },
                    "technician_payout": {
                        "type": "number",
                        "example": 22500
                    },
                    "currency": {
                        "type": "string",
                        "example": "TZS"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "pending",
                            "completed",
                            "failed",
                            "refunded"
                        ]
                    },
                    "payment_method": {
                        "type": "string",
                        "enum": [
                            "mpesa",
                            "airtel",
                            "tigopesa",
                            "halopesa",
                            "visa",
                            "mastercard"
                        ]
                    },
                    "phone_number": {
                        "type": "string",
                        "example": "255712345678"
                    },
                    "paid_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "Review": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 5
                    },
                    "rating": {
                        "type": "integer",
                        "maximum": 5,
                        "minimum": 1,
                        "example": 5
                    },
                    "comment": {
                        "type": "string",
                        "example": "Excellent work!"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "customer": {
                        "$ref": "#/components/schemas/User"
                    }
                },
                "type": "object"
            },
            "Wallet": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "balance": {
                        "type": "number",
                        "example": 50000
                    },
                    "pending_balance": {
                        "type": "number",
                        "example": 10000
                    },
                    "total_earned": {
                        "type": "number",
                        "example": 200000
                    },
                    "total_withdrawn": {
                        "type": "number",
                        "example": 150000
                    },
                    "currency": {
                        "type": "string",
                        "example": "TZS"
                    }
                },
                "type": "object"
            },
            "Complaint": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 3
                    },
                    "subject": {
                        "type": "string",
                        "example": "Technician did not show up"
                    },
                    "description": {
                        "type": "string"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "open",
                            "under_review",
                            "resolved",
                            "dismissed"
                        ]
                    },
                    "resolution_notes": {
                        "type": "string"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "WithdrawalRequest": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 2
                    },
                    "reference": {
                        "type": "string",
                        "example": "WDR-XXXXXXXXXX"
                    },
                    "amount": {
                        "type": "number",
                        "example": 30000
                    },
                    "currency": {
                        "type": "string",
                        "example": "TZS"
                    },
                    "method": {
                        "type": "string",
                        "enum": [
                            "mpesa",
                            "airtel",
                            "tigopesa",
                            "halopesa",
                            "bank"
                        ]
                    },
                    "account_number": {
                        "type": "string",
                        "example": "255712345678"
                    },
                    "account_name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "pending",
                            "approved",
                            "processing",
                            "completed",
                            "rejected"
                        ]
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "PaginatedMeta": {
                "properties": {
                    "current_page": {
                        "type": "integer",
                        "example": 1
                    },
                    "last_page": {
                        "type": "integer",
                        "example": 5
                    },
                    "per_page": {
                        "type": "integer",
                        "example": 10
                    },
                    "total": {
                        "type": "integer",
                        "example": 48
                    }
                },
                "type": "object"
            },
            "Error": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Unauthorized"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Enter the token returned from /auth/login or /auth/register",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Registration, login, logout"
        }
    ]
}